<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F8F9FA">

    <!-- App header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📞 NotifyTechAI"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginTop="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Call Sync System"
        android:textSize="14sp"
        android:textColor="#6C757D"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="40dp" />

    <!-- Agent info card -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAgentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agent: Loading…"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

            <TextView
                android:id="@+id/tvWebhookUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Webhook: Not configured"
                android:textSize="12sp"
                android:textColor="#6C757D"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status card -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync Status"
                android:textSize="12sp"
                android:textColor="#6C757D"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking permissions…"
                android:textSize="15sp"
                android:textColor="#28A745" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Action buttons -->
    <Button
        android:id="@+id/btnCheckPermissions"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Check Permissions"
        android:textSize="15sp"
        android:backgroundTint="#1A1A2E"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnTestSync"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Send Test Ping to Webhook"
        android:textSize="15sp"
        android:backgroundTint="#0077B6"
        android:layout_marginBottom="40dp" />

    <!-- Footer info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calls sync automatically after each call ends."
        android:textSize="12sp"
        android:textColor="#ADB5BD"
        android:gravity="center"
        android:layout_gravity="center_horizontal" />

</LinearLayout>
